@{
    Layout = "_RedeemLayout";
    ViewData["Title"] = "Redeem Your Reward";
}

<div class="min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="w-full max-w-md">
        <div class="text-center mb-6">
            <div class="flex justify-center mb-3">
                <div class="bg-white p-3 rounded-2xl shadow-sm inline-block">
                    <img src="~/images/logo.png" alt="Colorvision Paints" class="h-16 object-contain" />
                </div>
            </div>
            <h1 class="text-2xl font-bold text-white">Colorvision Paints</h1>
            <p class="text-white text-opacity-80 text-sm">Scan & Win Rewards</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-6">
            @if (ViewBag.Status == "invalid")
            {
                <div class="text-center py-8">
                    <div class="w-16 h-16 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-times-circle text-red-500 text-3xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Invalid Code</h2>
                    <p class="text-gray-500">@ViewBag.Message</p>
                </div>
            }
            else if (ViewBag.Status == "redeemed")
            {
                <div class="text-center py-8">
                    <div class="w-16 h-16 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-exclamation-triangle text-yellow-500 text-3xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Already Redeemed</h2>
                    <p class="text-gray-500">This code has already been redeemed.</p>
                </div>
            }
            else if (ViewBag.Status == "success")
            {
                <div class="text-center py-8">
                    <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-500 text-3xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Congratulations! 🎉</h2>
                    <div class="bg-green-50 rounded-xl p-4 mb-4">
                        <p class="text-3xl font-bold text-green-600">₹@ViewBag.Reward</p>
                        <p class="text-sm text-green-700 mt-1">Reward Earned</p>
                    </div>
                    <p class="text-gray-500 text-sm">Your reward has been recorded and will be credited to your UPI within 24 hours.</p>
                </div>
            }
            else if (ViewBag.Status == "error")
            {
                <div class="text-center py-8">
                    <div class="w-16 h-16 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-times-circle text-red-500 text-3xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Error</h2>
                    <p class="text-gray-500">@ViewBag.Message</p>
                </div>
            }
            else if (ViewBag.Status == "valid")
            {
                <div id="instaCheckStep" class="text-center space-y-4">
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Almost there!</h2>
                    <p class="text-gray-500 text-sm mb-4">You must follow our Instagram page to claim your reward.</p>
                    <a href="@ViewBag.InstagramUrl" target="_blank" onclick="startInstaTimer()" class="w-full inline-block py-3 rounded-xl text-white font-medium shadow-lg hover:opacity-90 transition" style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);">
                        <i class="fab fa-instagram mr-2"></i> Follow us on Instagram
                    </a>
                    <div id="instaStatus" class="mt-4 text-center text-sm font-medium text-gray-500 hidden"></div>
                </div>

                <div id="claimFormStep" class="hidden">
                    <h2 class="text-lg font-bold text-gray-900 mb-4 text-center">Enter Your Details</h2>
                    <form method="post" action="/Redeem/Submit" class="space-y-4">
                        <input type="hidden" name="code" value="@ViewBag.Code" />
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                            <input type="text" name="userName" required placeholder="Enter your name"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Mobile Number</label>
                            <input type="tel" name="mobileNumber" required placeholder="10-digit mobile number" pattern="[0-9]{10}"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">UPI ID</label>
                            <input type="text" name="upiId" required placeholder="example@upi"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                        </div>
                        <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                            <i class="fas fa-gift mr-2"></i> Claim Reward
                        </button>
                    </form>
                </div>
                
                <script>
                    function startInstaTimer() {
                        if(window.timerStarted) return;
                        window.timerStarted = true;
                        
                        const status = document.getElementById('instaStatus');
                        const formStep = document.getElementById('claimFormStep');
                        const instaStep = document.getElementById('instaCheckStep');
                        
                        status.classList.remove('hidden');
                        status.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Waiting for completion...';
                        
                        setTimeout(() => {
                            status.innerHTML = '<i class="fas fa-check-circle text-green-500 mr-2"></i> Verification complete.';
                            setTimeout(() => {
                                instaStep.classList.add('hidden');
                                formStep.classList.remove('hidden');
                            }, 1000);
                        }, 5000); // 5 seconds
                    }
                </script>
            }
        </div>

        <p class="text-center text-xs text-white text-opacity-60 mt-6">Powered by Informa Pavlion Software Solutions Pvt Ltd</p>
    </div>
</div>
